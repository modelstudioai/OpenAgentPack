{
	"compilerOptions": {
		"target": "ES2020",
		"lib": ["ES2020", "DOM", "DOM.Iterable"],
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "react-jsx",
		"strict": true,
		"esModuleInterop": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"skipLibCheck": true,
		"noEmit": true,
		"allowImportingTsExtensions": true,
		"types": ["vite/client", "bun"],
		"paths": {
			"@/*": ["./src/*"],
			"@openagentpack/playbooks": ["../../packages/playbooks/src/index.ts"]
		}
	},
	"include": ["src"]
}
